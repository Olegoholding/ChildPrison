<Page x:Class="diplomApp.View.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="900"
      Title="EmployeesPage"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - список сотрудников -->
        <Border BorderThickness="0,0,3,0" BorderBrush="#1a1a1a" Background="#f5f5f5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border BorderThickness="0,0,0,3" BorderBrush="#1a1a1a" Background="#1a1a1a">
                    <TextBlock Text=" СОТРУДНИКИ" 
                               FontSize="28" 
                               FontWeight="Black"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,15"
                               />
                </Border>

                <Button Grid.Row="1" 
                        Content="+ НОВЫЙ СОТРУДНИК"
                        Background="#1a1a1a"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Padding="20,12"
                        BorderThickness="2"
                        BorderBrush="#1a1a1a"
                        Cursor="Hand"
                        Margin="15,15,15,15"
                        Click="AddEmployee_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform X="2" Y="2"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Grid.Row="2" 
                           Text="ВЫБЕРИТЕ СОТРУДНИКА" 
                           FontSize="11" 
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"
                           />

                <ListBox Grid.Row="3" Style="{StaticResource BrutalistListBoxMinimal}"
                         x:Name="EmployeesListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="EmployeesListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#ddd" Padding="15,12">
                                <StackPanel>
                                    <TextBlock FontWeight="Black" FontSize="15">
                                        <Run Text="{Binding LastName}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding FirstName}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding MidName}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666" Margin="0,5,0,0">
                                        <Run Text="ПРОФЕССИЯ: "/>
                                        <Run Text="{Binding Profession, FallbackValue='НЕ УКАЗАНА'}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666">
                                        <Run Text="СТАТУС: "/>      
                                        <Run Text="{Binding Status.StatusName, FallbackValue='НЕ УКАЗАН'}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Правая панель -->
        <Border Grid.Column="1" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="MainScrollViewer">
                <StackPanel Margin="30" x:Name="MainStackPanel">

                    <TextBlock x:Name="TitleText" 
                               Text=" ИНФОРМАЦИЯ О СОТРУДНИКЕ"
                               FontSize="20"
                               FontWeight="Black"
                               Margin="0,20,0,25"
                               />

                    <!-- Блок: Личные данные -->
                    <Border BorderThickness="3" BorderBrush="#1a1a1a" Padding="20" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text=" ЛИЧНЫЕ ДАННЫЕ" 
                                       FontWeight="Black" 
                                       FontSize="14"
                                       Margin="0,-30,0,15"
                                       Background="White"
                                       Padding="0,0,10,0"
                                       />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="ФАМИЛИЯ:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="LastNameBox" VerticalContentAlignment="Center"
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="ИМЯ:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,8"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="FirstNameBox" VerticalContentAlignment="Center"
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="ОТЧЕСТВО:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="MidNameBox" VerticalContentAlignment="Center"
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Блок: Профессиональные данные -->
                    <Border BorderThickness="3" BorderBrush="#1a1a1a" Padding="20" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text=" ПРОФЕССИОНАЛЬНЫЕ ДАННЫЕ" 
                                       FontWeight="Black" 
                                       FontSize="14"
                                       Margin="0,-30,0,15"
                                       Background="White"
                                       Padding="0,0,10,0"
                                       />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="ПРОФЕССИЯ:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="ProfessionBox" VerticalContentAlignment="Center"
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5"
                                         TextChanged="ProfessionBox_TextChanged"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="ОБРАЗОВАНИЕ:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,8"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="EducationBox" 
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5" Height="60" TextWrapping="Wrap"/>

                                <!-- Замените старый ComboBox для статуса на этот -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="СТАТУС:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="StatusComboBox" VerticalContentAlignment="Center"
                                          BorderThickness="2" BorderBrush="#1a1a1a"
                                          Padding="8,5" Height="35" Margin="0,5"
                                          DisplayMemberPath="StatusName"
                                          SelectedValuePath="Id"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="ДАТА ПРИЁМА:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,8"/>
                                <DatePicker Grid.Row="3" Grid.Column="1" x:Name="HireDatePicker" VerticalContentAlignment="Center"
                                            BorderThickness="2" BorderBrush="#1a1a1a" 
                                            Margin="0,5" Height="35"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Блок: Группы (для воспитателей) -->
                    <Border x:Name="GroupsBorder" BorderThickness="3" BorderBrush="#1a1a1a" Padding="20" Margin="0,0,0,30" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text=" ЗАКРЕПЛЁННЫЕ ГРУППЫ" 
                                       FontWeight="Black" 
                                       FontSize="14"
                                       Margin="0,-30,0,15"
                                       Background="White"
                                       Padding="0,0,10,0"
                                       />

                            <TextBlock Text="* Только для воспитателей" FontSize="10" Foreground="#666" Margin="0,-5,0,10"/>

                            <ListBox x:Name="GroupsListBox" Style="{StaticResource BrutalistListBoxMinimal}"
                                     BorderThickness="2" 
                                     BorderBrush="#1a1a1a"
                                     Height="150"
                                     SelectionMode="Multiple">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="5">
                                            <Run Text="{Binding GroupName}"/>
                                            <Run Text=" ("/>
                                            <Run Text="{Binding RoomNumber, FallbackValue='НЕТ'}"/>
                                            <Run Text=")"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,30">
                        <Button Content="СОХРАНИТЬ" 
                                Background="#1a1a1a"
                                Foreground="White"
                                FontWeight="Black"
                                FontSize="13"
                                Padding="25,12"
                                BorderThickness="2"
                                BorderBrush="#1a1a1a"
                                Cursor="Hand"
                                Click="SaveEmployee_Click"
                                Width="130"
                                Height="50"
                                Margin="0,0,15,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#333333"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="2" Y="2"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="УДАЛИТЬ" 
                                Background="#cc3333"
                                Foreground="White"
                                FontWeight="Black"
                                FontSize="13"
                                Padding="25,12"
                                BorderThickness="2"
                                BorderBrush="#1a1a1a"
                                Cursor="Hand"
                                Click="DeleteEmployee_Click"
                                Width="130"
                                x:Name="DeleteButton"
                                Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#dd4444"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="2" Y="2"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="StatusText" 
                               Foreground="#cc3333" 
                               FontWeight="Bold"
                               FontSize="12"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>