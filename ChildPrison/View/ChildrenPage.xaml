<Page x:Class="diplomApp.View.ChildrenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:diplomApp.View"
      mc:Ignorable="d" 
      d:DesignHeight="850" d:DesignWidth="800"
      Title="ChildrenPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - список детей -->
        <Border BorderThickness="0,0,3,0" BorderBrush="#1a1a1a" Background="#f5f5f5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border BorderThickness="0,0,0,3" BorderBrush="#1a1a1a" Background="#1a1a1a">
                    <TextBlock Text="ДЕТИ" 
                               FontSize="28" 
                               FontWeight="Black"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,15"
                               />
                </Border>

                <Button Grid.Row="1" 
                        Content="+ НОВЫЙ РЕБЁНОК"
                        Background="#1a1a1a"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Padding="20,12"
                        BorderThickness="2"
                        BorderBrush="#1a1a1a"
                        Cursor="Hand"
                        Margin="15,15,15,15"
                        Click="AddChild_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform X="2" Y="2"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Grid.Row="2" 
                           Text="ВЫБЕРИТЕ РЕБЁНКА" 
                           FontSize="11" 
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"
                           />

                <ListBox Grid.Row="3" 
         x:Name="ChildrenListBox"
         Style="{StaticResource BrutalistListBoxMinimal}"
         SelectionChanged="ChildrenListBox_SelectionChanged"
         Margin="10,0,10,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#dddddd" Padding="15,12">
                                <StackPanel>
                                    <TextBlock FontWeight="Black" FontSize="15">
                        <Run Text="{Binding LastName}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding FirstName}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding MidName}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666" Margin="0,5,0,0">
                        <Run Text="ГРУППА: "/>
                        <Run Text="{Binding Group.GroupName, FallbackValue='НЕ НАЗНАЧЕНА'}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666">
                        <Run Text="РОДИТЕЛЬ: "/>
                        <Run Text="{Binding Parent.LastName, FallbackValue=''}"/>
                        <Run Text="{Binding Parent.FirstName, FallbackValue=''}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
            </Grid>
        </Border>

        <!-- Правая панель -->
        <Border Grid.Column="1" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30">

                    <TextBlock x:Name="TitleText" 
                               Text="ИНФОРМАЦИЯ О РЕБЁНКЕ"
                               FontSize="20"
                               FontWeight="Black"
                               Margin="0,20,0,25"
                               />

                    <!-- Блок: Ребёнок -->
                    <Border BorderThickness="3" BorderBrush="#1a1a1a" Padding="20" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text=" РЕБЁНОК" 
                                       FontWeight="Black" 
                                       FontSize="14"
                                       Margin="0,-30,0,15"
                                       Background="White"
                                       Padding="0,0,10,0"
                                       />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="ФАМИЛИЯ:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="LastNameBox" VerticalContentAlignment="Center"
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="ИМЯ:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,8"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="FirstNameBox" VerticalContentAlignment="Center"
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="ОТЧЕСТВО:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="MidNameBox" VerticalContentAlignment="Center"
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="ДАТА РОЖД.:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,8"/>
                                <DatePicker Grid.Row="3" Grid.Column="1" x:Name="BirthDatePicker" VerticalAlignment="Center"
                                            BorderThickness="2" BorderBrush="#1a1a1a" VerticalContentAlignment="Center" 
                                            Margin="0,5" Height="35"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderThickness="3" BorderBrush="#1a1a1a" Padding="20" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text=" РОДИТЕЛЬ" 
                                       FontWeight="Black" 
                                       FontSize="14"
                                       Margin="0,-30,0,15"
                                       Background="White"
                                       Padding="0,0,10,0"
                                       />

                            <CheckBox x:Name="NewParentCheckBox" 
                                      Content="ДОБАВИТЬ НОВОГО РОДИТЕЛЯ" 
                                      FontWeight="Bold"
                                      FontSize="12"
                                      Margin="0,0,0,15"
                                      Checked="NewParentCheckBox_Checked"
                                      Unchecked="NewParentCheckBox_Unchecked"/>

                            <StackPanel x:Name="ExistingParentPanel">
                                <TextBlock Text="ВЫБЕРИТЕ РОДИТЕЛЯ:" FontWeight="Bold" FontSize="12" Margin="0,5,0,5"/>
                                <ComboBox x:Name="ParentComboBox" 
                                          BorderThickness="2"                                           
                                          BorderBrush="#1a1a1a"
                                          VerticalContentAlignment="Center"
                                          Padding="8,5"
                                          Height="35"
                                          SelectionChanged="ParentComboBox_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel x:Name="NewParentPanel" Visibility="Collapsed">
                                <TextBlock Text="ФАМИЛИЯ:" FontWeight="Bold" FontSize="12" Margin="0,5,0,5"/>
                                <TextBox x:Name="ParentLastNameBox" BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" Margin="0,5"/>

                                <TextBlock Text="ИМЯ:" FontWeight="Bold" FontSize="12" Margin="0,5,0,5"/>
                                <TextBox x:Name="ParentFirstNameBox" BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" Margin="0,5"/>

                                <TextBlock Text="ОТЧЕСТВО:" FontWeight="Bold" FontSize="12" Margin="0,5,0,5"/>
                                <TextBox x:Name="ParentMiddleNameBox" BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" Margin="0,5"/>

                                <TextBlock Text="КОНТАКТЫ:" FontWeight="Bold" FontSize="12" Margin="0,5,0,5"/>
                                <TextBox x:Name="ParentContactBox" BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" Margin="0,5" Height="60" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Блок: Группа -->
                    <Border BorderThickness="3" BorderBrush="#1a1a1a" Padding="20" Margin="0,0,0,30">
                        <StackPanel>
                            <TextBlock Text=" ГРУППА" 
                                       FontWeight="Black" 
                                       FontSize="14"
                                       Margin="0,-30,0,15"
                                       Background="White"
                                       Padding="0,0,10,0"
                                       />

                            <ComboBox x:Name="GroupComboBox" 
                                      VerticalContentAlignment="Center" 
                                      BorderThickness="2" 
                                      BorderBrush="#1a1a1a"
                                      Padding="8,5"
                                      Height="35"
                                      DisplayMemberPath="GroupName"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,30">
                        <Button Content="СОХРАНИТЬ" 
                                Background="#1a1a1a"
                                Foreground="White"
                                FontWeight="Black"
                                FontSize="13"
                                Padding="25,12"
                                BorderThickness="2"
                                BorderBrush="#1a1a1a"
                                Cursor="Hand"
                                Click="SaveChild_Click"
                                Width="130"
                                Height="50"
                                Margin="0,0,15,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#333333"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="2" Y="2"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="УДАЛИТЬ" 
                                Background="#cc3333"
                                Foreground="White"
                                FontWeight="Black"
                                FontSize="13"
                                Padding="25,12"
                                BorderThickness="2"
                                BorderBrush="#1a1a1a"
                                Cursor="Hand"
                                Click="DeleteChild_Click"
                                Width="130"
                                x:Name="DeleteButton"
                                Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#dd4444"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="2" Y="2"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="StatusText" 
                               Foreground="#cc3333" 
                               FontWeight="Bold"
                               FontSize="12"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
