<Page x:Class="diplomApp.View.Nutrition.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="700"
      Title="ProductsPage"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - список продуктов -->
        <Border BorderThickness="0,0,2,0" BorderBrush="#1a1a1a" Background="#fafafa">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ПРОДУКТЫ" FontSize="20" FontWeight="Black" 
                           HorizontalAlignment="Center" Margin="0,15,0,10"/>

                <Button Grid.Row="1" Content="+ НОВЫЙ ПРОДУКТ"
                        Background="#1a1a1a" Foreground="White" FontWeight="Bold"
                        Padding="15,10" Margin="15,0,15,15" Cursor="Hand"
                        Click="AddProduct_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderThickness="2" BorderBrush="#1a1a1a">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform X="2" Y="2"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <ListBox Grid.Row="2" x:Name="ProductsListBox" Background="Transparent" BorderThickness="0" Style="{StaticResource BrutalistListBoxMinimal}"
                         SelectionChanged="ProductsListBox_SelectionChanged" d:ItemsSource="{d:SampleData ItemCount=5}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#ddd" Padding="12,10">
                                <StackPanel>
                                    <TextBlock FontWeight="Black" FontSize="14" Text="{Binding ProductName}"/>
                                    <TextBlock FontSize="11" Foreground="#666">
                                        <Run Text="КОЛИЧЕСТВО: "/><Run Text="{Binding Quantity, FallbackValue='0'}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666">
                                        <Run Text="ПОСТАВЩИК: "/><Run Text="{Binding Supplier.Name, FallbackValue='НЕ УКАЗАН'}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Правая панель - форма -->
        <Border Grid.Column="1" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25">
                    <TextBlock x:Name="TitleText" Text="ИНФОРМАЦИЯ О ПРОДУКТЕ"
                               FontSize="18" FontWeight="Black" Margin="0,15,0,25"/>

                    <Border BorderThickness="2" BorderBrush="#1a1a1a" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="НАЗВАНИЕ:" FontWeight="Bold" FontSize="12"/>
                            <TextBox x:Name="ProductNameBox" BorderThickness="2" BorderBrush="#1a1a1a" 
                                     Padding="8,6" Margin="0,5,0,15"/>

                            <TextBlock Text="КОЛИЧЕСТВО:" FontWeight="Bold" FontSize="12"/>
                            <TextBox x:Name="QuantityBox" BorderThickness="2" BorderBrush="#1a1a1a" 
                                     Padding="8,6" Margin="0,5,0,15"/>

                            <TextBlock Text="ПОСТАВЩИК:" FontWeight="Bold" FontSize="12"/>
                            <ComboBox x:Name="SupplierComboBox" BorderThickness="2" BorderBrush="#1a1a1a"
                                      Padding="8,5" Margin="0,5,0,15" Height="35"
                                      DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="СОХРАНИТЬ" Background="#1a1a1a" Foreground="White"
                                FontWeight="Black" Padding="20,10" Height="50" Width="120" Margin="0,0,10,0"
                                Click="SaveProduct_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderThickness="2" BorderBrush="#1a1a1a">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="2" Y="2"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="DeleteButton" Content="УДАЛИТЬ" Background="#cc3333" Foreground="White"
                                FontWeight="Black" Padding="20,10" Width="120" Visibility="Collapsed"
                                Click="DeleteProduct_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderThickness="2" BorderBrush="#1a1a1a">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="2" Y="2"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="StatusText" Foreground="#cc3333" FontWeight="Bold" 
                               Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>