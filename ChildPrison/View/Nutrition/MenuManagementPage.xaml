<Page x:Class="diplomApp.View.Nutrition.MenuManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="MenuManagementPage"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border BorderThickness="0,0,0,2" BorderBrush="#1a1a1a" Background="#1a1a1a">
            <TextBlock Text="УПРАВЛЕНИЕ МЕНЮ" 
                       FontSize="24" 
                       FontWeight="Black"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,15"
                       />
        </Border>

        <!-- Панель управления -->
        <Border Grid.Row="1" BorderThickness="0,0,0,2" BorderBrush="#1a1a1a" Background="#f5f5f5" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ДЕНЬ НЕДЕЛИ:" FontWeight="Bold" FontSize="14" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="DayOfWeekComboBox" Width="150" Height="35" 
                              BorderThickness="2" BorderBrush="#1a1a1a"
                              SelectionChanged="DayOfWeekComboBox_SelectionChanged">
                        <ComboBoxItem Content="ПОНЕДЕЛЬНИК" Tag="1"/>
                        <ComboBoxItem Content="ВТОРНИК" Tag="2"/>
                        <ComboBoxItem Content="СРЕДА" Tag="3"/>
                        <ComboBoxItem Content="ЧЕТВЕРГ" Tag="4"/>
                        <ComboBoxItem Content="ПЯТНИЦА" Tag="5"/>
                        <ComboBoxItem Content="СУББОТА" Tag="6"/>
                        <ComboBoxItem Content="ВОСКРЕСЕНЬЕ" Tag="7"/>
                    </ComboBox>
                </StackPanel>

                <Button Grid.Column="1" Content="СОХРАНИТЬ МЕНЮ" 
                        Background="#1a1a1a" Foreground="White" FontWeight="Bold"
                        Padding="20,10" Margin="10,0" Cursor="Hand"
                        Click="SaveMenu_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderThickness="2" BorderBrush="#1a1a1a">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform X="2" Y="2"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Content="ЭКСПОРТ В PDF" 
                        Background="#333333" Foreground="White" FontWeight="Bold"
                        Padding="20, 0" Margin="0,0,10,0" Cursor="Hand"
                        Click="ExportToPdf_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderThickness="2" BorderBrush="#1a1a1a">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform X="2" Y="2"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Таблица меню -->
        <Border Grid.Row="2" Background="White" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!-- Заголовки -->
                    <Border Grid.Column="0" BorderThickness="2,2,1,2" BorderBrush="#1a1a1a" Background="#1a1a1a" Padding="10">
                        <TextBlock Text="ПРИЁМ ПИЩИ" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </Border>
                    <Border Grid.Column="1" BorderThickness="1,2,1,2" BorderBrush="#1a1a1a" Background="#1a1a1a" Padding="10">
                        <TextBlock Text="ЗАВТРАК" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2" BorderThickness="1,2,1,2" BorderBrush="#1a1a1a" Background="#1a1a1a" Padding="10">
                        <TextBlock Text="ВТОРОЙ ЗАВТРАК" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </Border>
                    <Border Grid.Column="3" BorderThickness="1,2,1,2" BorderBrush="#1a1a1a" Background="#1a1a1a" Padding="10">
                        <TextBlock Text="ОБЕД" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="4" BorderThickness="1,2,2,2" BorderBrush="#1a1a1a" Background="#1a1a1a" Padding="10">
                        <TextBlock Text="ПОЛДНИК" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Строки (первая) -->
                    <Border Grid.Row="1" Grid.Column="0" BorderThickness="2,1,1,1" BorderBrush="#1a1a1a" Background="#fafafa" Padding="10">
                        <TextBlock Text="БЛЮДО 1" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" BorderThickness="1,1,1,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="Breakfast1ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"
                                  Tag="breakfast_1"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="2" BorderThickness="1,1,1,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="SecondBreakfast1ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"
                                  Tag="second_breakfast_1"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="3" BorderThickness="1,1,1,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="Lunch1ComboBox"  Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"
                                  Tag="lunch_1"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="4" BorderThickness="1,1,2,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="Snack1ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"
                                  Tag="snack_1"/>
                    </Border>

                    <!-- Строка 2 -->
                    <Border Grid.Row="2" Grid.Column="0" BorderThickness="2,1,1,1" BorderBrush="#1a1a1a" Background="#fafafa" Padding="10">
                        <TextBlock Text="БЛЮДО 2" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" BorderThickness="1,1,1,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="Breakfast2ComboBox"  Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="2" BorderThickness="1,1,1,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="SecondBreakfast2ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="3" BorderThickness="1,1,1,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="Lunch2ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="4" BorderThickness="1,1,2,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="Snack2ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"/>
                    </Border>

                    <!-- Строка 3 -->
                    <Border Grid.Row="3" Grid.Column="0" BorderThickness="2,1,1,1" BorderBrush="#1a1a1a" Background="#fafafa" Padding="10">
                        <TextBlock Text="БЛЮДО 3" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="1" BorderThickness="1,1,1,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="Breakfast3ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="2" BorderThickness="1,1,1,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="SecondBreakfast3ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="3" BorderThickness="1,1,1,1" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="Lunch3ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="4" BorderThickness="1,1,2,2" BorderBrush="#1a1a1a" Padding="5">
                        <ComboBox x:Name="Snack3ComboBox" Margin="5"
                                  DisplayMemberPath="DishName" SelectedValuePath="Id"/>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>