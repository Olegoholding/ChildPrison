<Page x:Class="diplomApp.View.GroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="900"
      Title="GroupsPage"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border BorderThickness="0,0,3,0" BorderBrush="#1a1a1a" Background="#f5f5f5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border BorderThickness="0,0,0,3" BorderBrush="#1a1a1a" Background="#1a1a1a">
                    <TextBlock Text="ГРУППЫ" 
                               FontSize="28" 
                               FontWeight="Black"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,15"/>
                </Border>

                <Button Grid.Row="1" 
                        Content="+ НОВАЯ ГРУППА"
                        Background="#1a1a1a"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Padding="20,12"
                        BorderThickness="2"
                        BorderBrush="#1a1a1a"
                        Cursor="Hand"
                        Margin="15,15,15,15"
                        Click="AddGroup_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform X="2" Y="2"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Grid.Row="2" 
                           Text="ВЫБЕРИТЕ ГРУППУ" 
                           FontSize="11" 
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <ListBox Grid.Row="3" Style="{StaticResource BrutalistListBoxMinimal}"
                         x:Name="GroupsListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="GroupsListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#ddd" Padding="15,12">
                                <StackPanel>
                                    <TextBlock FontWeight="Black" FontSize="15">
                                        <Run Text="{Binding GroupName}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666" Margin="0,5,0,0">
                                        <Run Text="КАБИНЕТ: "/>
                                        <Run Text="{Binding RoomNumber, FallbackValue='НЕ УКАЗАН'}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666">
                                        <Run Text="ВОСПИТАТЕЛЬ: "/>
                                        <Run Text="{Binding TeacherFullName, Mode=OneWay, FallbackValue='НЕ НАЗНАЧЕН'}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666">
                                        <Run Text="ДЕТЕЙ: "/>
                                        <Run Text="{Binding ChildrenCount, Mode=OneWay, FallbackValue='0'}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="MainScrollViewer">
                <Grid Margin="30" x:Name="MainStackPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition />
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TitleText" 
                               Text="ИНФОРМАЦИЯ О ГРУППЕ"
                               FontSize="20"
                               FontWeight="Black"
                               Margin="0,20,0,25"/>

                    <Border BorderThickness="3" BorderBrush="#1a1a1a" Grid.Row="1" Padding="20" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text=" ОСНОВНАЯ ИНФОРМАЦИЯ" 
                                       FontWeight="Black" 
                                       FontSize="14"
                                       Margin="0,-30,0,15"
                                       Background="White"
                                       Padding="0,0,10,0"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="НАЗВАНИЕ:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="GroupNameBox" VerticalContentAlignment="Center"
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="КАБИНЕТ:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,8"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="RoomNumberBox" VerticalContentAlignment="Center"
                                         BorderThickness="2" BorderBrush="#1a1a1a" Padding="8,6" FontSize="13" Margin="0,5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="ВОСПИТАТЕЛЬ:" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="TeacherComboBox" VerticalContentAlignment="Center"
                                          BorderThickness="2" BorderBrush="#1a1a1a"
                                          Padding="8,5" Height="35" Margin="0,5"
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Id"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderThickness="3" Grid.Row="2" BorderBrush="#1a1a1a" Padding="20" Margin="0,0,0,30">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text=" ДЕТИ В ГРУППЕ" 
                                       FontWeight="Black" 
                                       FontSize="14"
                                       Margin="0,-30,0,15"
                                       Background="White"
                                       Padding="0,0,10,0"/>

                            <TextBlock Text="* Выберите детей для добавления в группу" FontSize="10" Foreground="#666" Margin="0,-5,0,10"/>

                            <ListBox Grid.Row="1" x:Name="ChildrenListBox" Style="{StaticResource BrutalistListBoxMinimal}"
                                     BorderThickness="2" 
                                     BorderBrush="#1a1a1a"
                                     SelectionMode="Multiple">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="#ddd" Padding="12,10">
                                            <StackPanel>
                                                <TextBlock FontWeight="Black" FontSize="14">
                                                    <Run Text="{Binding LastName}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding FirstName}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding MidName}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="#666" Margin="0,3,0,0">
                                                    <Run Text="РОДИТЕЛЬ: "/>
                                                    <Run Text="{Binding Parent.LastName, FallbackValue=''}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Parent.FirstName, FallbackValue=''}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="#666">
                                                    <Run Text="ДАТА РОЖД.: "/>
                                                    <Run Text="{Binding BirthDate, StringFormat='{}{0:dd.MM.yyyy}', FallbackValue='НЕ УКАЗАНА'}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Right" Margin="0,0,0,30">
                        <Button Content="СОХРАНИТЬ" 
                                Background="#1a1a1a"
                                Foreground="White"
                                FontWeight="Black"
                                FontSize="13"
                                Padding="25,12"
                                BorderThickness="2"
                                BorderBrush="#1a1a1a"
                                Cursor="Hand"
                                Click="SaveGroup_Click"
                                Width="130"
                                Height="50"
                                Margin="0,0,15,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#333333"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="2" Y="2"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="УДАЛИТЬ" 
                                Background="#cc3333"
                                Foreground="White"
                                FontWeight="Black"
                                FontSize="13"
                                Padding="25,12"
                                BorderThickness="2"
                                BorderBrush="#1a1a1a"
                                Cursor="Hand"
                                Click="DeleteGroup_Click"
                                Width="130"
                                x:Name="DeleteButton"
                                Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#dd4444"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="2" Y="2"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Row="5" x:Name="StatusText" 
                               Foreground="#cc3333" 
                               FontWeight="Bold"
                               FontSize="12"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>