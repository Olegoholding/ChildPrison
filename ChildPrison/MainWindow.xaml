<Window x:Class="ChildPrison.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChildPrison"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent" 
        Title="MainWindow" Height="550" Width="900">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="5" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>
    <Grid >
        <Border Background="Black" Margin="5,5,0,0"/>

        <Border BorderThickness="2" Margin="0,0,5,5" Background="White" BorderBrush="Black">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>


                <Border BorderThickness="0,0,0,2" Background="Transparent" BorderBrush="Black" MouseDown="Border_MouseDown">
                    <Grid>
                        <TextBlock Text="Главное окно" FontWeight="Bold" VerticalAlignment="Center" FontSize="20" Margin="20,0,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                            <Button Width="40" Style="{StaticResource ExitButton}" Margin="0,0,5,0" Background="#39dcff" Click="Button_Click_2">
                                <TextBlock Text="-" FontWeight="Black" FontSize="20"/>
                            </Button>
                            <Button Width="40" Style="{StaticResource ExitButton}" Margin="0,0,5,0" Background="#dd7eff" Click="Button_Click_1">
                                <TextBlock Text="◳" FontWeight="Black" FontSize="20"/>
                            </Button>
                            <Button Width="40" Style="{StaticResource ExitButton}" Click="Button_Click"  Background="#f15f60">
                                <TextBlock Text="×" FontWeight="Black" FontSize="20"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel  Margin="20,15,0,20">
                        <RadioButton x:Name="child" Content="СПИСОК ДЕТЕЙ" Style="{StaticResource MenuRadioButton}" Tag="#f15f60"/>
                        <RadioButton Content="СПИСОК РАБЛОТНИКОВ" Style="{StaticResource MenuRadioButton}"/>
                        <RadioButton Content="ПАНЕЛЬ АДМИНА" Style="{StaticResource MenuRadioButton}"/>
                        <RadioButton Content="ПАНЕЛЬ ПИТАНИЯ" Style="{StaticResource MenuRadioButton}"/>
                    </StackPanel>

                    <Grid Grid.Column="1" Margin="20">
                        <Border  Background="Black"  Margin="10,10,0,0"
                    BorderBrush="Black" BorderThickness="2"/>

                        <Border Background="White" 
                    BorderBrush="Black" BorderThickness="2" Margin="0,0,10,10">

                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>

</Window>
