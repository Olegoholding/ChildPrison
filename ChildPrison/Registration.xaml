<Window x:Class="ChildPrison.Registration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChildPrison"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent" 
        Title="Registration" Height="400" Width="800">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="5" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>
    <Grid >
        <Border Background="Black" Margin="5,5,0,0"/>

        <Border BorderThickness="2" Margin="0,0,5,5" Background="White" BorderBrush="Black">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="МДОУ Светловский детский сад «Солнышко»" Foreground="#1a1a1a" TextAlignment="Center" FontSize="18" HorizontalAlignment="Center" Margin="20,15,20,5" TextWrapping="WrapWithOverflow" FontFamily="Courier New"/>

                    <Grid Margin="0,0,0,10" Height="250" Width="250">
                        <Border  Background="#1a1a1a"  Margin="5,5,0,0"
             BorderBrush="#1a1a1a" BorderThickness="2"/>

                        <Border Background="White"  
            BorderBrush="#1a1a1a" BorderThickness="2" Margin="0,0,5,5">

                            <Image Margin="15,15,15,0"  Source="Style/Images/Image.png"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="Составление питания" TextAlignment="Center" FontSize="24" HorizontalAlignment="Center" Margin="20,0,20,0" TextWrapping="WrapWithOverflow" FontWeight="Black"/>

                </StackPanel>

                <Border Background="Black" Margin="0" Width="2" HorizontalAlignment="Right"/>

                <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>


                <Border BorderThickness="0,0,0,2" Background="Transparent" BorderBrush="Black" MouseDown="Border_MouseDown">
                    <Grid>
                        <TextBlock Text="Вход" FontWeight="Bold" VerticalAlignment="Center" FontSize="20" Margin="20,0,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                            <Button Width="40" Style="{StaticResource ExitButton}" Margin="0,0,5,0" Background="#39dcff" Click="Button_Click_2">
                                <TextBlock Text="-" FontWeight="Black" FontSize="20"/>
                            </Button>
                            <Button Width="40" Style="{StaticResource ExitButton}" Click="Button_Click"  Background="#f15f60">
                                <TextBlock Text="×" FontWeight="Black" FontSize="20"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <StackPanel Margin="20">
                            <TextBlock FontWeight="Black" Foreground="#1a1a1a" Text="Логин:" FontSize="24"/>
                        <Grid Margin="0,0,0,10" >
                                <Border  Background="#1a1a1a"  Margin="5,5,0,0"
                                     BorderBrush="#1a1a1a" BorderThickness="2"/>

                            <Border Background="White" Height="40" 
                                    BorderBrush="#1a1a1a" BorderThickness="2" Margin="0,0,5,5">

                                <TextBox Name="LoginBox" FontWeight="Medium" FontSize="16" VerticalContentAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" BorderThickness="0" MinWidth="330"/>
                            </Border>
                        </Grid>

                            <TextBlock FontWeight="Black" Text="Пароль:" Foreground="#1a1a1a" FontSize="24"/>
                        <Grid Margin="0,0,0,10" >
                                <Border  Background="#1a1a1a"  Margin="5,5,0,0"
                                     BorderBrush="#1a1a1a" BorderThickness="2"/>

                            <Border Background="White" Height="40" 
                                    BorderBrush="#1a1a1a" BorderThickness="2" Margin="0,0,5,5">

                                <TextBox Name="PassBox" FontWeight="Medium" VerticalContentAlignment="Center" FontSize="16"  HorizontalAlignment="Left" Margin="5,0,0,0" BorderThickness="0" MinWidth="330"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Margin="20">
                        <Border Background="#1a1a1a" Margin="0,0,0,20" Height="2"/>

                    <Button Name="ChangeBtn" Height="50"  Style="{StaticResource RegistrationButton}" Click="ChangeBtn_Click">
                        <TextBlock Name="TextRegBtn" Text="Войти" FontSize="18" FontWeight="Medium"/>
                    </Button>
                </StackPanel>
            </Grid >
            </Grid>
        </Border>
    </Grid>
</Window>
