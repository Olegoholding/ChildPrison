<Window x:Class="ChildPrison.Registration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChildPrison"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent" 
        Title="Registration" Height="600" Width="400">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="5" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>
    <Grid >
        <Border Background="Black" Margin="5,5,0,0"/>

        <Border BorderThickness="2" Margin="0,0,5,5" Background="White" BorderBrush="Black">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>


                <Border BorderThickness="0,0,0,2" Background="Transparent" BorderBrush="Black" MouseDown="Border_MouseDown">
                    <Grid>
                        <TextBlock Text="Вход" FontWeight="Bold" VerticalAlignment="Center" FontSize="20" Margin="20,0,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                            <Button Width="40" Style="{StaticResource ExitButton}" Margin="0,0,5,0" Background="#39dcff" Click="Button_Click_2">
                                <TextBlock Text="-" FontWeight="Black" FontSize="20"/>
                            </Button>
                            <Button Width="40" Style="{StaticResource ExitButton}" Click="Button_Click"  Background="#f15f60">
                                <TextBlock Text="×" FontWeight="Black" FontSize="20"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <StackPanel Margin="20">
                        <TextBlock FontWeight="Black" Text="Логин:" FontSize="24"/>
                        <Grid Margin="0,0,0,10" >
                            <Border  Background="Black"  Margin="5,5,0,0"
                                     BorderBrush="Black" BorderThickness="2"/>

                            <Border Background="White" Height="40" 
                                    BorderBrush="Black" BorderThickness="2" Margin="0,0,5,5">

                                <TextBox Name="LoginBox" FontWeight="Medium" FontSize="16" VerticalContentAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" BorderThickness="0" MinWidth="330"/>
                            </Border>
                        </Grid>

                        <TextBlock FontWeight="Black" Text="Пароль:" FontSize="24"/>
                        <Grid Margin="0,0,0,10" >
                            <Border  Background="Black"  Margin="5,5,0,0"
                                     BorderBrush="Black" BorderThickness="2"/>

                            <Border Background="White" Height="40" 
                                    BorderBrush="Black" BorderThickness="2" Margin="0,0,5,5">

                                <TextBox Name="PassBox" FontWeight="Medium" VerticalContentAlignment="Center" FontSize="16"  HorizontalAlignment="Left" Margin="5,0,0,0" BorderThickness="0" MinWidth="330"/>
                            </Border>
                        </Grid>

                        <TextBlock Name="KeyLbl" FontWeight="Black" Text="Ключ:" FontSize="24"/>
                        <Grid Name="KeyGrid" Margin="0,0,0,20" >
                            <Border  Background="Black"  Margin="5,5,0,0"
             BorderBrush="Black" BorderThickness="2"/>

                            <Border Name="KeyBorder" Background="White" Height="40" 
            BorderBrush="Black" BorderThickness="2" Margin="0,0,5,5">

                                <TextBox Name="KeyBox" FontWeight="Medium" VerticalContentAlignment="Center" FontSize="16"  HorizontalAlignment="Left" Margin="5,0,0,0" BorderThickness="0" MinWidth="330"/>
                            </Border>
                        </Grid>

                        <RadioButton Name="AuthBtn" GroupName="1" Height="50"  Style="{StaticResource RegistrationRadioButton}" Checked="AuthBtn_Checked">
                            <TextBlock Name="AuthBtnText" Text="Зарегистрироваться" FontSize="18" FontWeight="Medium"/>
                        </RadioButton>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Margin="20">
                    <Border Background="Black" Margin="0,0,0,20" Height="2"/>

                    <RadioButton Name="ChangeBtn" GroupName="1" Height="50"  Style="{StaticResource RegistrationRadioButton}" Click="ChangeBtn_Click">
                        <TextBlock Name="TextRegBtn" Text="Зарегистрироваться" FontSize="18" FontWeight="Medium"/>
                    </RadioButton>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
